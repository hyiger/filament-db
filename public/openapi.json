            "type": "array",
            "items": { "$ref": "#/components/schemas/Calibration" }
          },
          "presets": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Preset" }
          },
          "spoolWeight": { "type": "number", "nullable": true, "description": "Empty spool weight in grams" },
          "netFilamentWeight": { "type": "number", "nullable": true, "description": "Net filament weight in grams" },
          "totalWeight": { "type": "number", "nullable": true, "description": "Current total weight (spool + filament) in grams" },
          "tdsUrl": { "type": "string", "nullable": true, "description": "Technical data sheet URL" },
